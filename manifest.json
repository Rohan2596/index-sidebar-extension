{
  "manifest_version": 3,
  "name": "Finzo – Real-time Index Watchlist",
  "short_name": "Finzo",
  "version": "1.2.0",
  "description": "Track global indices with real-time data, 52-week highs/lows, and daily market insights in a powerful sidebar.",
  "permissions": ["sidePanel", "storage", "alarms"],  "host_permissions": [
    "https://docs.google.com/spreadsheets/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "Open Finzo Dashboard"
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },

  "minimum_chrome_version": "114"
}